DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# Optional when using global slash command registration
DISCORD_GUILD_ID=
BOT_PREFIX=!
# Local Lavalink:
# LAVALINK_HOST=127.0.0.1
# Pi / remote Lavalink over VPN:
# LAVALINK_HOST=100.x.y.z
LAVALINK_HOST=127.0.0.1
LAVALINK_PORT=2333
LAVALINK_PASSWORD=youshallnotpass
DATABASE_URL=./data/music-bot.sqlite
# Set to true only when you want to route YouTube resolution through resolver-service.
RESOLVER_ENABLED=false
RESOLVER_BASE_URL=http://127.0.0.1:8080
RESOLVER_TIMEOUT_MS=30000
LOG_LEVEL=info

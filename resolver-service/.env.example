RESOLVER_HOST=127.0.0.1
RESOLVER_PORT=8080
RESOLVER_LOG_LEVEL=info
YTDLP_BINARY=yt-dlp
YTDLP_TIMEOUT_SECONDS=30
RESOLVER_CACHE_TTL_SECONDS=300
YTDLP_COOKIES_FILE=
YTDLP_EXTRACTOR_ARGS=
# Put multiple extractor args on one line with || separators, for example:
# YTDLP_EXTRACTOR_ARGS=youtube:player_client=mweb;formats=missing_pot||youtubepot-bgutilhttp:base_url=http://127.0.0.1:4416
YTDLP_SLEEP_INTERVAL_SECONDS=
RESOLVER_PUBLIC_BASE_URL=http://127.0.0.1:8080
RESOLVER_STREAM_TTL_SECONDS=900
RESOLVER_ENABLE_DIRECT_PROXY=false
